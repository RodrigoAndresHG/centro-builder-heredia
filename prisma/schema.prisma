// Centro Builder HeredIA MVP
// Initial data model for auth, roles, products, programs, access and purchases.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  roleKey       String    @default("INVITADO") @map("role_key")
  signupSource  String?   @map("signup_source")
  utmSource     String?   @map("utm_source")
  utmMedium     String?   @map("utm_medium")
  utmCampaign   String?   @map("utm_campaign")
  signupIntent  String?   @map("signup_intent")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  accesses       Access[]
  purchases      Purchase[]
  lessonProgress LessonProgress[]
  assistantUsage AssistantUsage[]
  emailSequence  EmailSequenceState?
  certificates   Certificate[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Role {
  key         String   @id
  label       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String?
  stripePriceId String?  @map("stripe_price_id")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  programs  Program[]
  accesses  Access[]
  purchases Purchase[]

  @@map("products")
}

model Program {
  id             String        @id @default(cuid())
  productId      String?       @map("product_id")
  slug           String        @unique
  title          String
  description    String?
  isPublished    Boolean       @default(false) @map("is_published")
  status         ProgramStatus @default(DRAFT)
  sortOrder      Int           @default(0) @map("sort_order")
  opensAt        DateTime?     @map("opens_at")
  presaleMessage String?       @map("presale_message") @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  product      Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  modules      Module[]
  lessons      Lesson[]
  accesses     Access[]
  certificates Certificate[]

  @@map("programs")
}

// Certificado de finalización por programa. Se emite una sola vez por
// usuario+programa al llegar al 100% de lecciones publicadas. `code` es el
// identificador público no adivinable de /cert/[code]; `recipientName` es un
// snapshot del nombre al momento de emitir (el cert no cambia si el usuario
// se renombra). `revokedAt` permite invalidarlo (ej. reembolso) sin borrarlo.
model Certificate {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  programId     String    @map("program_id")
  code          String    @unique
  recipientName String    @map("recipient_name")
  issuedAt      DateTime  @default(now()) @map("issued_at")
  revokedAt     DateTime? @map("revoked_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@map("certificates")
}

enum ProgramStatus {
  DRAFT
  PRESALE
  OPEN
}

model Module {
  id          String   @id @default(cuid())
  programId   String   @map("program_id")
  slug        String
  title       String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  program Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([programId, slug])
  @@map("modules")
}

model Lesson {
  id                String   @id @default(cuid())
  programId         String   @map("program_id")
  moduleId          String?  @map("module_id")
  slug              String
  title             String
  description       String?
  content           String?  @db.Text
  videoUrl          String?  @map("video_url")
  videoProvider     String?  @map("video_provider")
  streamVideoId     String?  @unique @map("stream_video_id")
  videoStatus       String   @default("NONE") @map("video_status")
  videoTitle        String?  @map("video_title")
  videoThumbnailUrl String?  @map("video_thumbnail_url")
  videoDuration     Int?     @map("video_duration")
  isPreview         Boolean  @default(false) @map("is_preview")
  sortOrder         Int      @default(0) @map("sort_order")
  isPublished       Boolean  @default(false) @map("is_published")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  program   Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  module    Module?          @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  progress  LessonProgress[]
  prompts   LessonPrompt[]
  resources LessonResource[]

  @@unique([programId, slug])
  @@map("lessons")
}

model LessonPrompt {
  id        String   @id @default(cuid())
  lessonId  String   @map("lesson_id")
  title     String
  body      String   @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_prompts")
}

enum LessonResourceType {
  LINK
  DOWNLOAD
  REFERENCE
}

model LessonResource {
  id          String             @id @default(cuid())
  lessonId    String             @map("lesson_id")
  title       String
  description String?
  url         String
  type        LessonResourceType @default(LINK)
  sortOrder   Int                @default(0) @map("sort_order")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_resources")
}

model Access {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  productId String?      @map("product_id")
  programId String?      @map("program_id")
  status    String       @default("ACTIVE")
  source    AccessSource @default(MANUAL)
  startsAt  DateTime     @default(now()) @map("starts_at")
  expiresAt DateTime?    @map("expires_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  program Program? @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@unique([userId, programId])
  @@map("accesses")
}

enum AccessSource {
  STRIPE
  MANUAL
  TEST
}

model Purchase {
  id                      String    @id @default(cuid())
  userId                  String    @map("user_id")
  productId               String?   @map("product_id")
  status                  String    @default("PENDING")
  amountCents             Int?      @map("amount_cents")
  currency                String?
  stripeCustomerId        String?   @map("stripe_customer_id")
  stripeCheckoutSessionId String?   @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?   @map("stripe_payment_intent_id")
  purchasedAt             DateTime? @map("purchased_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("purchases")
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  lessonId    String   @map("lesson_id")
  completedAt DateTime @default(now()) @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

model EarlyAccessLead {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  source    String
  status    String   @default("PENDIENTE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([source])
  @@index([status])
  @@map("early_access_leads")
}

enum BuilderUpdateType {
  NOVEDAD
  TIP
  IA
  RECOMENDACION
}

model BuilderUpdate {
  id          String            @id @default(cuid())
  title       String
  type        BuilderUpdateType @default(NOVEDAD)
  summary     String
  content     String            @db.Text
  imageUrl    String?           @map("image_url")
  isPublished Boolean           @default(false) @map("is_published")
  publishedAt DateTime?         @map("published_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([isPublished, publishedAt])
  @@index([type])
  @@map("builder_updates")
}

enum PromptPlatform {
  CLAUDE
  CHATGPT
  GEMINI
  MULTI
}

model PromptAsset {
  id          String         @id @default(cuid())
  title       String
  description String?
  body        String         @db.Text
  platform    PromptPlatform @default(MULTI)
  category    String
  isPremium   Boolean        @default(false) @map("is_premium")
  isPublished Boolean        @default(false) @map("is_published")
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([isPublished, platform])
  @@index([category])
  @@map("prompt_assets")
}

// Contador diario de mensajes al asistente IA, por usuario (anti-abuso).
model AssistantUsage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  day       String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@map("assistant_usage")
}

// Rate limit por IP+minuto para los endpoints públicos /api/external/*
// (serverless-safe: el contador vive en la DB, no en memoria del proceso).
// `bucket` = "<ip>:<minuto-ISO>". Las filas viejas se pueden purgar luego.
model ExternalSignupThrottle {
  id        String   @id @default(cuid())
  bucket    String   @unique
  count     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("external_signup_throttle")
}

// Clics a links que no aceptan UTMs (ej. el canal de WhatsApp), registrados
// vía redirect interno /go/* para poder medir la atribución por fuente.
model LinkClickEvent {
  id        String   @id @default(cuid())
  target    String
  src       String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([target, src])
  @@map("link_click_events")
}

enum EmailSequenceStatus {
  pending
  done
  unsubscribed
  failed
}

// Estado del drip de onboarding por email (5 correos en 7 días) por usuario.
// step = índice del PRÓXIMO correo a enviar (0..5). Al llegar a 5 → done.
model EmailSequenceState {
  id               String              @id @default(cuid())
  userId           String              @unique @map("user_id")
  email            String
  step             Int                 @default(0)
  status           EmailSequenceStatus @default(pending)
  attempts         Int                 @default(0)
  nextSendAt       DateTime            @map("next_send_at")
  lastSentAt       DateTime?           @map("last_sent_at")
  unsubscribeToken String              @unique @map("unsubscribe_token")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, nextSendAt])
  @@map("email_sequence_state")
}
