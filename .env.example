DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# Email magic-link login (Auth.js Nodemailer provider). The login UI
# shows the "Acceso por correo" form automatically when BOTH of these
# are set. Recommended provider: Resend (resend.com) — free tier,
# easy SMTP. Example with Resend:
#   EMAIL_SERVER="smtp://resend:re_XXXXXXXX@smtp.resend.com:587"
#   EMAIL_FROM="Builder HeredIA <no-reply@tudominio.com>"
EMAIL_SERVER="smtp://USER:PASSWORD@SMTP_HOST:587"
EMAIL_FROM="Centro Builder HeredIA <no-reply@example.com>"

APPLE_CLIENT_ID="replace-with-apple-client-id"
APPLE_CLIENT_SECRET="replace-with-apple-client-secret"

STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_PUBLISHABLE_KEY="pk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
STRIPE_IDEACASH_PRICE_ID="price_replace_me"

STRIPE_CHECKOUT_LOGO_FILE_ID=""
STRIPE_CHECKOUT_ICON_FILE_ID=""

CLOUDFLARE_ACCOUNT_ID="replace-with-cloudflare-account-id"
CLOUDFLARE_STREAM_TOKEN="replace-with-cloudflare-stream-token"
CLOUDFLARE_STREAM_REQUIRE_SIGNED_URLS="false"

# Microsoft Clarity project ID. Optional — leave empty in local dev
# to keep your dev traffic out of Clarity's dashboard. Get it from
# https://clarity.microsoft.com after creating a project.
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# WhatsApp Community invite link shown across the LMS (dashboard,
# support, post-checkout). Optional — there is a sensible default in
# src/lib/community.ts. Set this to override without a code change.
NEXT_PUBLIC_COMMUNITY_URL=""

# Asistente IA del LMS (widget de chat en /app). Crea la API key en
# https://console.anthropic.com → API Keys. Sin la key, el widget se
# muestra pero responde que el asistente no está disponible.
ANTHROPIC_API_KEY=""
# Opcional: modelo del asistente (default claude-haiku-4-5). Sube a
# claude-sonnet-4-6 o claude-opus-4-8 si quieres más capacidad.
ASSISTANT_MODEL=""

SEED_ADMIN_EMAIL="admin@example.com"
SEED_ACCESS_EMAIL="usuario-pago@example.com"
